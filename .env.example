# ── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ── Database (Postgres) ──────────────────────────────
DATABASE_URL=postgresql://nous:nous@localhost:5432/nous

# ── Auth (USE STRONG RANDOM IN PROD) ─────────────────
JWT_ACCESS_SECRET=change-me-access-32+chars-random
JWT_REFRESH_SECRET=change-me-refresh-32+chars-random-different
ACCESS_TOKEN_TTL=900        # 15 min (seconds)
REFRESH_TOKEN_TTL_DAYS=30

# ── PagBank (subscriptions v4) ───────────────────────
PAGBANK_ENV=sandbox                                          # sandbox | production
PAGBANK_TOKEN=your_pagbank_bearer_token
PAGBANK_WEBHOOK_SECRET=random-secret-to-verify-signatures
PAGBANK_WEBHOOK_URL=https://your-domain/api/v1/billing/webhook

# ─── Nous product wiring (optional) ──────────────────
NOUS_CONTEXT_API_URL=http://localhost:4400                  # nous-context (thinkbrew) server
